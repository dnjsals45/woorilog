# Backend local environment example.
# Values are examples only. Do not commit real secrets.

SPRING_PROFILES_ACTIVE=local

MYSQL_DATABASE=woorilog
MYSQL_USER=woorilog
MYSQL_PASSWORD=woorilog_local_password
MYSQL_ROOT_PASSWORD=woorilog_root_password
MYSQL_HOST=localhost
MYSQL_PORT=3306

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

JWT_SECRET=woorilog-secret-key-for-development-should-be-long-enough-for-hmac-sha256
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600
REFRESH_COOKIE_SECURE=false

DEV_LOGIN_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:5173
